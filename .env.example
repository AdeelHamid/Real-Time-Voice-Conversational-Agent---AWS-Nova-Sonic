AWS_REGION=ap-northeast-1
NOVA_SONIC_MODEL_ID=amazon.nova-2-sonic-v1:0
MODULAR_REASON_MODEL_ID=deepseek.v3-v1:0
PORT=3000

# CloudWatch app logs
CW_LOG_ENABLED=true
CW_LOG_GROUP=/voice-agent/app
CW_LOG_STREAM_PREFIX=local-

# AWS credentials
AWS_ACCESS_KEY_ID=PASTE_YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=PASTE_YOUR_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=
